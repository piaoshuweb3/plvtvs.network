# ============================================================
# ERC-4337 Account Abstraction (Pimlico — https://pimlico.io)
# Register at https://dashboard.pimlico.io for a free API key.
# Free tier supports Base Sepolia with generous rate limits.
# ============================================================
# Bundler endpoint — used to submit & relay UserOperations
NEXT_PUBLIC_BUNDLER_URL=https://api.pimlico.io/v2/84532/rpc?apikey=pim_V7mmeu9ZcynCcUizWRmBuj
# Paymaster endpoint — sponsors gas for UserOperations (optional)
NEXT_PUBLIC_PAYMASTER_URL=https://api.pimlico.io/v2/84532/rpc?apikey=pim_V7mmeu9ZcynCcUizWRmBuj

# Email (Resend) — https://resend.com
# 注册获取 API key (免费层: 100 emails/day)
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=PLVTVS.ONE <noreply@plvtvs.one>

# ─── PLVTVS Smart Contract ───
# Deploy PlutusSubscription.sol via Remix (see scripts/deploy-contract.md)
# After deployment, replace the placeholder below with the deployed address:
NEXT_PUBLIC_PLVTVS_SUBSCRIPTION_CONTRACT=0x0000000000000000000000000000000000000000

# Ultimate admin wallet — set in contract constructor, never changes on deploy
NEXT_PUBLIC_PLVTVS_ADMIN_WALLET=0x10687368eF1be3f178de0fCCf5EdfF49e1C258B1

# Target Base chain: base-sepolia (testnet) or base (mainnet)
NEXT_PUBLIC_BASE_CHAIN=base-sepolia
